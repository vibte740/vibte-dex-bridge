# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── Security ──────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=your_tradingview_webhook_secret_here

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Wallet ────────────────────────────────────────────────────────────────────
PRIVATE_KEY=your_wallet_private_key_never_commit_this

# ── Hyperliquid ───────────────────────────────────────────────────────────────
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
HYPERLIQUID_TESTNET=false

# ── dYdX ──────────────────────────────────────────────────────────────────────
DYDX_API_KEY=
DYDX_API_SECRET=
DYDX_API_PASSPHRASE=
DYDX_NETWORK=mainnet   # mainnet | testnet

# ── Trading ───────────────────────────────────────────────────────────────────
DEFAULT_DEX=hyperliquid          # hyperliquid | dydx
RISK_PER_TRADE_PCT=1             # % of account equity per trade
MAX_LEVERAGE=5
ALLOWED_SYMBOLS=BTC,ETH,SOL
